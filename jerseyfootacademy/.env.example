# ─────────────────────────────────────────────────────────────────────────────
# JerseyFootAcademy — environment variables
# Copy this file to `.env` and fill in the values. NEVER commit your real .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# Local example: postgresql://postgres:postgres@localhost:5432/jerseyfootacademy
# Production (Vercel Postgres / Neon / Supabase): use the pooled connection string.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jerseyfootacademy?schema=public"
# Direct (non-pooled) connection, used by Prisma migrations on serverless providers.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/jerseyfootacademy?schema=public"

# ── NextAuth ─────────────────────────────────────────────────────────────────
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Optional OAuth providers (leave blank to disable)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
# From `stripe listen` locally, or the Dashboard webhook endpoint in production.
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# ── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="JerseyFootAcademy"

# ── Email (Resend) ───────────────────────────────────────────────────────────
# Powers newsletter welcome emails and order confirmations. Leave blank to
# disable email sending (the app still works; emails are simply skipped).
# Get a key at https://resend.com and verify your sending domain.
RESEND_API_KEY=""
# Verified sender, e.g. "JerseyFootAcademy <hello@yourdomain.com>"
EMAIL_FROM=""
