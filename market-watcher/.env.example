# ============================================================================
# Market Watcher — environment configuration (Phase 1)
# Copy to `.env` and fill in. NEVER commit your real .env.
# ============================================================================

# --- Postgres (used by docker-compose to create the DB) ---------------------
POSTGRES_USER=watcher
POSTGRES_PASSWORD=change_me
POSTGRES_DB=watcher

# DATABASE_URL / REDIS_URL are set automatically by docker-compose.
# For running the backend OUTSIDE docker, set them yourself, e.g.:
# DATABASE_URL=postgresql+asyncpg://watcher:change_me@localhost:5432/watcher
# REDIS_URL=redis://localhost:6379/0

# --- Anthropic (REQUIRED) ---------------------------------------------------
# Your existing API key (pay-as-you-go). Claude Pro does NOT grant API access.
ANTHROPIC_API_KEY=
# Cheapest model, used by every agent. Configurable per agent below.
DEFAULT_LLM_MODEL=claude-haiku-4-5
# Reserved for occasional complex syntheses (Phase 2+).
SYNTHESIS_LLM_MODEL=claude-sonnet-4-6
LLM_MAX_OUTPUT_TOKENS=1024

# --- Market data: crypto (CoinGecko Demo — free) ----------------------------
# Create a free Demo key: https://www.coingecko.com/en/api/pricing
COINGECKO_API_KEY=
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# --- Market data: stocks / gold / oil ---------------------------------------
# Pick one provider: "twelvedata" or "finnhub".
STOCKS_PROVIDER=twelvedata
# Twelve Data free tier: https://twelvedata.com/pricing
TWELVEDATA_API_KEY=
# Finnhub free tier (alternative): https://finnhub.io/pricing
FINNHUB_API_KEY=

# --- Telegram alerts --------------------------------------------------------
# Create a bot via @BotFather, then get your chat id (see README).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Scheduling (cost lever #1: raise intervals to cut LLM spend) -----------
MARKET_POLL_SECONDS=120
NEWS_AGENT_INTERVAL_SECONDS=300
# Optional per-agent model override (else DEFAULT_LLM_MODEL):
NEWS_AGENT_MODEL=
AGENTS_ENABLED=true

# --- Alert engine -----------------------------------------------------------
ALERT_MIN_INTENSITY=4
ALERT_MIN_CONFIDENCE=0.6
ALERT_COOLDOWN_MINUTES=30

# --- Budget guard -----------------------------------------------------------
MONTHLY_BUDGET_USD=50
PAUSE_AGENTS_ON_BUDGET=true

# --- API / dashboard --------------------------------------------------------
# If set, the dashboard API requires Authorization: Bearer <token>.
# Leave empty for local dev (auth disabled).
DASHBOARD_API_TOKEN=
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_PER_MINUTE=120

# Where the browser reaches the backend API (frontend build-time).
NEXT_PUBLIC_API_BASE=http://localhost:8000
